{
  "name": "@reformlabs/qlit",
  "version": "2.8.0",
  "description": "High-performance CLI translator and i18n automation tool with DeepL integration, parallel processing, and auto-generated localization.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qlit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/locales dist/ || xcopy /E /I src\\locales dist\\locales",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "qlit",
    "translate",
    "lingva",
    "cli",
    "translator",
    "typescript",
    "open source",
    "javascript",
    "i18n",
    "deepl"
  ],
  "author": "Reform Labs",
  "license": "RFLS-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reformlabs/qlit.git"
  },
  "bugs": {
    "url": "https://github.com/reformlabs/qlit/issues"
  },
  "homepage": "https://github.com/reformlabs/qlit#readme",
  "dependencies": {
    "chalk": "^4.1.2",
    "clipboardy": "^2.3.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.12",
    "@types/ora": "^3.1.0",
    "@types/clipboardy": "^1.1.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}